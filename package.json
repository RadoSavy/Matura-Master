{
  "name": "matura-master",
  "version": "2.0.0",
  "description": "Bulgarian language learning platform with Firebase",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsc --watch",
    "serve": "npx http-server public -p 8080 -c-1",
    "dev:all": "npm run watch & npm run serve",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf public/dist"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "firebase": "^10.7.1"
  }
}
